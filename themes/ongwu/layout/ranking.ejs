<!-- 页面标题设置 -->
<% page.title = '踩踩网站' %>

<div class="guestbook-page">
    <div class="container">
        <header class="page-header">
            <h1 class="page-title">踩踩网站</h1>
            <p class="page-description">在这里留下你的足迹，分享你的想法</p>
        </header>
        
        <!-- 评论表单 -->
        <div class="comment-form-section">
            <div class="comment-form-card">
                <h3 class="form-title">发表留言</h3>
                <form class="comment-form" id="commentForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="username">用户名 *</label>
                            <input type="text" id="username" name="username" required placeholder="请输入你的用户名">
                        </div>
                        <div class="form-group">
                            <label for="captcha">验证码 *</label>
                            <div class="captcha-group">
                                <input type="text" id="captcha" name="captcha" required placeholder="请输入验证码">
                                <div class="captcha-image" id="captchaImage">
                                    <span id="captchaText"></span>
                                </div>
                                <button type="button" class="refresh-captcha" id="refreshCaptcha">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M1 4V10H7M23 20V14H17M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14L18.36 18.36A9 9 0 0 1 3.51 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="comment">留言内容 *</label>
                        <textarea id="comment" name="comment" rows="4" required placeholder="在这里写下你的留言..."></textarea>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="submit-btn">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M22 2L11 13M22 2L15 22L11 13M22 2L2 9L11 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            发表留言
                        </button>
                    </div>
                </form>
            </div>
        </div>
        
        <!-- 评论列表 -->
        <div class="comments-section">
            <div class="comments-header">
                <h3 class="comments-title">访客留言 (<span id="totalComments">0</span>)</h3>
                <div class="comments-filter">
                    <select id="sortOrder" class="sort-select">
                        <option value="newest">最新优先</option>
                        <option value="oldest">最早优先</option>
                    </select>
                </div>
            </div>
            
            <div class="comments-list" id="commentsList">
                <!-- 评论将通过JavaScript动态加载 -->
            </div>
            
            <!-- 分页 -->
            <div class="pagination" id="pagination">
                <!-- 分页将通过JavaScript动态生成 -->
            </div>
        </div>
    </div>
</div>

<!-- 回复模态框 -->
<div class="reply-modal" id="replyModal">
    <div class="reply-overlay" id="replyOverlay"></div>
    <div class="reply-container">
        <div class="reply-header">
            <h3>回复留言</h3>
            <button class="reply-close" id="replyClose">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
        </div>
        <form class="reply-form" id="replyForm">
            <div class="form-group">
                <label for="replyUsername">用户名 *</label>
                <input type="text" id="replyUsername" name="replyUsername" required placeholder="请输入你的用户名">
            </div>
            <div class="form-group">
                <label for="replyCaptcha">验证码 *</label>
                <div class="captcha-group">
                    <input type="text" id="replyCaptcha" name="replyCaptcha" required placeholder="请输入验证码">
                    <div class="captcha-image" id="replyCaptchaImage">
                        <span id="replyCaptchaText"></span>
                    </div>
                    <button type="button" class="refresh-captcha" id="refreshReplyCaptcha">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M1 4V10H7M23 20V14H17M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14L18.36 18.36A9 9 0 0 1 3.51 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                </div>
            </div>
            <div class="form-group">
                <label for="replyContent">回复内容 *</label>
                <textarea id="replyContent" name="replyContent" rows="3" required placeholder="在这里写下你的回复..."></textarea>
            </div>
            <div class="form-actions">
                <button type="button" class="cancel-btn" id="cancelReply">取消</button>
                <button type="submit" class="submit-btn">发表回复</button>
            </div>
        </form>
    </div>
</div>
